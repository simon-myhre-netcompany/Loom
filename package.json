{
  "name": "loom",
  "version": "0.1.0",
  "description": "Personal work-history aggregator. Read-only CLI connectors that emit a normalized activity-event stream for the `logg` skill to reason over.",
  "type": "module",
  "bin": {
    "loom": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "bash scripts/prepare.sh",
    "build": "tsc && bash scripts/build-helper.sh",
    "build:helper": "bash scripts/build-helper.sh",
    "dev": "tsx src/cli.ts",
    "loom": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
