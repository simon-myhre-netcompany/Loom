# Loom credentials — copy to .env and fill in. Secrets only ever live here
# (.env is gitignored). Configure only the sources you use: connectors are
# independent, and `loom status` shows what is ready vs. missing.
# Tip: `loom keys add --env NAME --expires DATE` can write the secret for you.

# --- Tempo (https://api.eu.tempo.io) -------------------------------------------
# Personal API token: Tempo > Settings > API integration > New token.
TEMPO_API_TOKEN=
# Your Atlassian accountId (find it via your Jira profile). Scopes worklog
# reads to you, and is REQUIRED for `loom tempo log`.
TEMPO_ACCOUNT_ID=

# --- Atlassian: Jira + Confluence share ONE token (Basic auth: email + token) --
# Token from https://id.atlassian.com/manage-profile/security/api-tokens
# See: loom guide jira  (Confluence reuses the same credentials)
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
# REQUIRED: your Jira site. Confluence defaults to the same site + /wiki.
JIRA_BASE_URL=https://your-site.atlassian.net
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki

# --- GitHub (https://api.github.com) -------------------------------------------
# Fine-grained read-only PATs. A PAT is locked to ONE resource owner, so add
# one var per account/org you work in — any suffix, as many as you like.
# Loom reads every GITHUB_TOKEN / GITHUB_TOKEN_* var and merges the results:
#   GITHUB_TOKEN_PERSONAL=github_pat_...
#   GITHUB_TOKEN_WORK=github_pat_...
#   GITHUB_TOKEN_CLIENTX=github_pat_...
# See: loom guide github
GITHUB_TOKEN_PERSONAL=

# --- Slack (user token xoxp- per workspace) -------------------------------------
# One app/token per workspace — any suffix, as many workspaces as you like.
# Loom reads every SLACK_TOKEN / SLACK_TOKEN_* var and merges the workspaces:
#   SLACK_TOKEN_WORK=xoxp-...
#   SLACK_TOKEN_COMMUNITY=xoxp-...
# See: loom guide slack
SLACK_TOKEN_WORK=

# --- Calendar (Linux/containers; macOS reads Apple Calendar via EventKit) -------
# Published-calendar / .ics links. Treat them like tokens (capability URLs).
# Any suffix, as many calendars as you like — Loom merges all CALENDAR_ICS_URL*:
#   CALENDAR_ICS_URL_WORK=https://outlook.office365.com/owa/calendar/....ics
# CALENDAR_ICS_URL=
