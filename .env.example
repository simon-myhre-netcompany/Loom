# Logger credentials (v1: env vars; migrate to macOS Keychain later).
# Copy to .env and fill in. .env is gitignored.

# --- Tempo (https://api.eu.tempo.io) ---
# Personal API token: Tempo > Settings > API integration > New token.
TEMPO_API_TOKEN=

# Your Jira/Atlassian accountId. Required to scope worklogs to just you.
# Find it at: https://oslo-kommune.atlassian.net/rest/api/2/myself  (field: accountId)
TEMPO_ACCOUNT_ID=

# --- GitHub (https://api.github.com) ---
# Fine-grained PATs, read-only (Metadata + Contents + Pull requests). One per
# resource owner: personal account, oslo-kommune org, etc. Logger reads every
# GITHUB_TOKEN / GITHUB_TOKEN_* var and merges the results.
# See: logger guide github
GITHUB_TOKEN_PERSONAL=
GITHUB_TOKEN_OSLO=
