# Logger credentials (v1: env vars; migrate to macOS Keychain later).
# Copy to .env and fill in. .env is gitignored.

# --- Tempo (https://api.eu.tempo.io) ---
# Personal API token: Tempo > Settings > API integration > New token.
TEMPO_API_TOKEN=

# Your Jira/Atlassian accountId. Required to scope worklogs to just you.
# Find it at: https://oslo-kommune.atlassian.net/rest/api/2/myself  (field: accountId)
TEMPO_ACCOUNT_ID=
